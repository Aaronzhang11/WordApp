<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC"
    android:padding="16dp">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="背词卡片"
            android:textColor="#1F3B5B"
            android:textSize="19sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="收藏"
            android:src="@android:drawable/btn_star_big_off" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="永久移除"
            android:src="@android:drawable/ic_menu_delete" />

    </LinearLayout>

    <!-- 单词卡片区域 -->
    <FrameLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/controlPanel"
        android:layout_below="@id/topBar"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="18dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/wordCardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">

                <!-- 正面：单词、音标、掌握等级 -->
                <LinearLayout
                    android:id="@+id/layoutCardFront"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvLevelBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="14dp"
                        android:paddingTop="7dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="7dp"
                        android:text="等级 0 · 待学习"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProgressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="掌握进度 0 / 3"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressLevel"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="160dp"
                        android:layout_height="7dp"
                        android:layout_marginTop="8dp"
                        android:max="3"
                        android:progress="0"
                        android:progressBackgroundTint="#E2E8F0"
                        android:progressTint="#475569" />

                    <TextView
                        android:id="@+id/tvWord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        android:gravity="center"
                        android:text="Spelling"
                        android:textColor="#1F2937"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPhonetic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="[phonetic]"
                        android:textColor="#718096"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tvFlipPrompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="38dp"
                        android:text="点击卡片翻看释义"
                        android:textColor="#2C5282"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- 背面：等级说明、中文释义 -->
                <LinearLayout
                    android:id="@+id/layoutCardBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvLevelDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="14dp"
                        android:paddingTop="7dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="7dp"
                        android:text="当前掌握程度：0级"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTranslation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:gravity="center"
                        android:lineSpacingExtra="6dp"
                        android:text="这里显示对应的中文解释及详细词义。"
                        android:textColor="#1F2937"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:text="根据记忆情况选择下方操作"
                        android:textColor="#718096"
                        android:textSize="13sp" />

                </LinearLayout>

            </RelativeLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- 翻转后显示的操作按钮 -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:visibility="invisible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForgot"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginRight="8dp"
            android:layout_weight="1"
            android:text="不认识"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="#D9534F"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemembered"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginLeft="8dp"
            android:layout_weight="1"
            android:text="认识"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="#2F9E66"
            app:cornerRadius="16dp" />

    </LinearLayout>

</RelativeLayout>