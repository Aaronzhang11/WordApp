<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="模拟自测卷"
                android:textColor="#203756"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnExitDictation"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_exit_button"
                android:paddingStart="13dp"
                android:paddingEnd="13dp"
                android:text="退出测试"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBarDictation"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="20dp"
            android:indeterminate="false"
            android:max="10"
            android:progress="0"
            android:progressBackgroundTint="#D6E0EC"
            android:progressTint="#2F5E97" />

        <TextView
            android:id="@+id/tvDictationQuestionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="第 1 / 10 题 · 请根据听到的单词拼写英文"
            android:textColor="#74849A"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_test_card"
            android:elevation="3dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="30dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="听写单词"
                android:textColor="#203756"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="可重复播放，听清后输入英文拼写"
                android:textColor="#7B8CA2"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnPlayWord"
                android:layout_width="230dp"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#3F7FE8"
                android:text="播放单词"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDictationHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="请点击播放按钮，听清单词后输入正确拼写"
            android:textColor="#72839A"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etDictationAnswer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_test_input"
            android:gravity="center_vertical"
            android:hint="请输入你听到的英文单词"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="#203756"
            android:textColorHint="#9AA8BA"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSubmitDictation"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2F5E97"
            android:text="提交答案"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNextDictation"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#2F5E97"
            android:text="下一题"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>