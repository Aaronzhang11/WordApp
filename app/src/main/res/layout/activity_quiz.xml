<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="10"
            android:progress="1"
            android:progressTint="#1F4E86" />

        <TextView
            android:id="@+id/tvQuestionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请根据以下释义选择正确的英文单词："
            android:textColor="#6F7F8F"
            android:textSize="17sp"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvQuestionContent"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#FFFFFF"
            android:gravity="center"
            android:padding="18dp"
            android:text="题目释义"
            android:textColor="#1D2A3A"
            android:textSize="25sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp">

            <Button
                android:id="@+id/btnOptionA"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#FFFFFF"
                android:text="option A"
                android:textAllCaps="false"
                android:textColor="#1F4E86"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOptionB"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#FFFFFF"
                android:text="option B"
                android:textAllCaps="false"
                android:textColor="#1F4E86"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOptionC"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#FFFFFF"
                android:text="option C"
                android:textAllCaps="false"
                android:textColor="#1F4E86"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOptionD"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#FFFFFF"
                android:text="option D"
                android:textAllCaps="false"
                android:textColor="#1F4E86"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDictation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="28dp">

            <Button
                android:id="@+id/btnSpeak"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="播放发音"
                android:textAllCaps="false"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/etDictInput"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:hint="请输入听到的英文单词"
                android:singleLine="true"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSubmitDict"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:text="提交"
                android:textAllCaps="false"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>